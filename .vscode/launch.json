{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Runserver",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["runserver"],
            "django": true,
            "justMyCode": false
        },
        {
            "name": "Django: Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "purpose": ["debug-test"],
            "justMyCode": false
        },
        {
            "name": "Django: Debug runserver on Docker",
            "type": "debugpy",
            "request": "attach",
            "connect": {"host": "localhost", "port": 5678},
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "/app"
                }
            ],
            "justMyCode": false
        },
        {
            "name": "Dashboard: Debug React App (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "preLaunchTask": "Dashboard: Start",
            "webRoot": "${workspaceFolder}/dashboard/src"
        },
        {
            "name": "Dashboard: Start and Attach to Chrome",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "preLaunchTask": "Dashboard: Start",
            "webRoot": "${workspaceFolder}/dashboard/src"
        },
    ]
}
