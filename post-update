#!/bin/sh
set -e

# Read the environment variables
if [ -r ../etc/env ]; then
    . ../etc/env
fi

export UV_PROJECT_ENVIRONMENT=${UV_PROJECT_ENVIRONMENT:-$HOME/venv}
if [ ! -e .venv ]; then
    ln -srv "$UV_PROJECT_ENVIRONMENT" .venv
fi

# Update the dashboard
if [ "$DISABLE_DASHBOARD_DEPLOY" = "1" ]; then
    echo "Not deploying Dashboard, since DISABLE_DASHBOARD_DEPLOY is set."
elif [ "$force_update" = "true" ] || \
       git diff --name-only "$prev_head..HEAD" | grep -q "^dashboard/"; then
    if [ "$TIER" != "prod" ]; then
        export VITE_API_URL="${VITE_API_URL:-https://testapi.parkkiopas.fi/}"
    fi
    [ -z "$VITE_API_URL" ] || echo "Using API base URL: $VITE_API_URL"
    cd dashboard
    NODE_ENV=production pnpm i --frozen-lockfile
    NODE_ENV=production pnpm build
    if [ -d ../../var ]; then
        rsync -av --delete dist/ ../../var/dashboard/
    fi
    cd ..
fi

# Update the backend
uv sync --frozen --no-default-groups

./manage.py collectstatic --noinput

if [ "$DISABLE_MIGRATIONS_ON_DEPLOY" = "1" ]; then
    echo "Skipping migrations, since DISABLE_MIGRATIONS_ON_DEPLOY is set."
else
    ./manage.py migrate --noinput
fi

# Send notification about succesful update
update_notify "Updated to $new_ver" || true
